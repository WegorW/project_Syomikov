''' Организовать словарь avto, содержащий 3 ключа (марки авто) и списки из трех моделей в качестве значений. 
 Обеспечить отображение вторых моделей по каждому авто, всех моделей словаря'''


 avto = {
    "Toyota": ["Corolla", "Camry", "RAV4"],
    "BMW": ["3 Series", "5 Series", "X5"],
    "Hyundai": ["Solaris", "Elantra", "Tucson"]
}

print("Вторые модели каждого бренда:")
for brand in avto:
    print(f"{brand}: {avto[brand][1]}")

print("\nВсе модели в словаре:")
for models in avto.values():
    for model in models:
        print(model)

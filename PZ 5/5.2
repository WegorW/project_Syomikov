''' Описать функцию PowerA234(A, B, C, D), вычисляющую вторую, третью и
 четвертую степень числа A и возвращающую эти степени соответственно в
переменные B, C и D. С помощью этой функции найти вторую, третью и
 четвертую степень пяти данных чисел'''

def PowerA234(A: float):
  
    B = A ** 2
    C = A ** 3
    D = A ** 4
    print(f"Для A={A}: B={B}, C={C}, D={D}")

N_numbers = 5
count = 0

while count < N_numbers:
    num = float(input("Введите число № {}: ".format(count + 1)))
    PowerA234(num)
    count += 1
